apiVersion: run.googleapis.com/v1
kind: Job
metadata:
  annotations:
    run.googleapis.com/client-name: gcloud
    run.googleapis.com/client-version: 546.0.0
  name: tw-stock-job
  labels:
    cloud.googleapis.com/location: asia-east1
spec:
  template:
    metadata:
      annotations:
        run.googleapis.com/client-name: gcloud
        run.googleapis.com/client-version: 546.0.0
        run.googleapis.com/execution-environment: gen2
    spec:
      taskCount: 1
      template:
        spec:
          containers:
          - env:
            - name: AUTO_SEND
              value: 'true'
            - name: DRY_RUN
              value: 'false'
            - name: TG_BOT_TOKEN
              valueFrom:
                secretKeyRef:
                  key: latest
                  name: TG_BOT_TOKEN
            - name: TG_CHAT_ID
              valueFrom:
                secretKeyRef:
                  key: latest
                  name: TG_CHAT_ID
            image: gcr.io/YOUR_PROJECT_ID/tw_stock:latest
            resources:
              limits:
                cpu: 1000m
                memory: 512Mi
          maxRetries: 1
          serviceAccountName: YOUR_SERVICE_ACCOUNT@YOUR_PROJECT_ID.iam.gserviceaccount.com
          timeoutSeconds: '600'

